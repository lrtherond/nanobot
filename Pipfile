[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
nanobot-ai = {path = ".", editable = true, extras = ["mqtt"]}

[dev-packages]
bandit = ">=1.8,<2.0"
black = ">=24.10,<26.0"
pytest = ">=9.0,<10.0"
pytest-asyncio = ">=1.3,<2.0"
ruff = ">=0.12,<1.0"

[requires]
python_version = "3.12"

[scripts]
format = "black nanobot/channels/mqtt.py tests/test_mqtt_channel.py"
format-check = "black --check nanobot/channels/mqtt.py tests/test_mqtt_channel.py"
lint = "ruff check nanobot/channels/mqtt.py tests/test_mqtt_channel.py"
security = "bandit -q -r nanobot/channels/mqtt.py"
test = "pytest tests/test_mqtt_channel.py"
